# Cyrano — Whisper Copilot Environment Variables

# NATS connection (shared with all services)
NATS_URL=nats://localhost:4222

# Postgres connection (shared Prisma client — used in future L2 memory persistence)
DATABASE_URL=postgresql://cnz_user:changeme@localhost:5432/chatnowzone

# Redis (reserved for future distributed session memory)
REDIS_HOST=localhost
REDIS_PORT=6379

# Cyrano latency SLOs (milliseconds) — override defaults if needed
CYRANO_IDEAL_LATENCY_MS=2000
CYRANO_HARD_CUTOFF_MS=4000

# ── Cyrano Layer 4 (enterprise multi-tenant Whisper API) ─────────────────
# Default per-tenant rate limit (requests/minute). Tenants may override
# at registration time via rate_limit_per_minute.
CYRANO_LAYER4_DEFAULT_RATE_LIMIT_PER_MINUTE=600
# Default per-API-key burst window (ms). Each key gets at most
# max(10, ceil(limit_per_minute / 60)) requests in this window.
CYRANO_LAYER4_BURST_WINDOW_MS=1000
# Lower bound on the per-key burst ceiling.
CYRANO_LAYER4_BURST_DEFAULT_CEILING=10
# Default voice profile (overridable per-domain — see voice bridge).
CYRANO_LAYER4_DEFAULT_VOICE_ID=cyrano_neutral_en
CYRANO_LAYER4_DEFAULT_LOCALE=en-US
