{
  "name": "chatnowzone-build",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint 'services/**/*.{ts,js}' --max-warnings 0",
    "lint:ci": "eslint 'services/**/*.{ts,js}' --max-warnings 0",
    "lint:fix": "eslint 'services/**/*.{ts,js}' --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "typecheck:api": "tsc --noEmit --project services/core-api/tsconfig.json",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push --skip-generate",
    "seed:scheduling": "ts-node scripts/seed-scheduling.ts",
    "ship-gate": "ts-node --transpile-only --project PROGRAM_CONTROL/tsconfig.json PROGRAM_CONTROL/ship-gate-verifier.ts"
  },
  "engines": {
    "node": ">=20 <23",
    "yarn": ">=1.22"
  },
  "dependencies": {
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/typeorm": "^11.0.1",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "decimal.js": "10.6.0",
    "nats": "^2.29.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.29"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bull": "^4.10.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "husky": "9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "15.5.2",
    "prettier": "^3.3.3",
    "prisma": "^6.19.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "services/**/*.{ts,js}": "eslint --max-warnings 0"
  }
}
